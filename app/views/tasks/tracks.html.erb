<%= render 'shared/page-header', title: 'Tracking', back: true %>

<%= turbo_frame_tag 'tracks-list' do %>

  <% if @project || @task %>
    <div class="mb-3">
      <% if @project %>
        <div class="d-flex align-items-center bg-white border rounded-3 shadow-sm px-3 py-2 mb-2">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-primary me-3 flex-shrink-0" style="width: 40px; height: 40px; background-color: rgba(var(--bs-primary-rgb), .1);">
            <i class="bi bi-folder-fill fs-5"></i>
          </span>
          <div class="flex-grow-1" style="min-width: 0;">
            <div class="text-uppercase text-muted fw-semibold" style="font-size: .7rem; letter-spacing: .05em;">Progetto</div>
            <div class="fw-semibold text-break lh-sm"><%= @project.name %></div>
          </div>
          <% unless @task %>
            <a href="<%= tasks_tracks_path(date: @date&.iso8601) %>" data-turbo-frame="tracks-list" class="btn btn-sm btn-link text-secondary ms-2 flex-shrink-0" aria-label="Rimuovi filtro progetto">
              <i class="bi bi-x-lg"></i>
            </a>
          <% end %>
        </div>
      <% end %>
      <% if @task %>
        <div class="d-flex align-items-center bg-white border rounded-3 shadow-sm px-3 py-2 mb-2">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-primary me-3 flex-shrink-0" style="width: 40px; height: 40px; background-color: rgba(var(--bs-primary-rgb), .1);">
            <i class="bi bi-check2-square fs-5"></i>
          </span>
          <div class="flex-grow-1" style="min-width: 0;">
            <div class="text-uppercase text-muted fw-semibold" style="font-size: .7rem; letter-spacing: .05em;">Task</div>
            <div class="fw-semibold text-break lh-sm"><%= @task.title %></div>
          </div>
          <a href="<%= tasks_tracks_path(project_id: @project_id, date: @date&.iso8601) %>" data-turbo-frame="tracks-list" class="btn btn-sm btn-link text-secondary ms-2 flex-shrink-0" aria-label="Rimuovi filtro task">
            <i class="bi bi-x-lg"></i>
          </a>
        </div>
      <% end %>
      <div class="text-end">
        <a href="<%= tasks_tracks_path(date: @date&.iso8601) %>" data-turbo-frame="tracks-list" class="small text-muted">
          <i class="bi bi-x-circle me-1"></i>Rimuovi tutti i filtri
        </a>
      </div>
    </div>
  <% end %>

  <div class="card">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <form method="GET" action="<%= tasks_tracks_path %>" class="d-flex align-items-center gap-2" data-controller="filters">
          <%= hidden_field_tag 'project_id', @project_id if @project_id %>
          <%= hidden_field_tag 'task_id', @task&.id if @task %>
          <label for="date" class="visually-hidden">Filtra per giornata</label>
          <input
            type="date"
            class="form-control form-control-sm"
            id="date"
            name="date"
            value="<%= @date&.iso8601 %>"
            max="<%= Date.current.iso8601 %>"
            data-action="change->filters#submit"
          >
          <% if @date %>
            <a href="<%= tasks_tracks_path(project_id: @project_id, task_id: @task&.id) %>" data-turbo-frame="tracks-list" class="small">Azzera</a>
          <% end %>
        </form>
        <div class="text-muted">
          Totale: <span class="fw-bold text-body"><%= track_time(@total) %></span>
        </div>
      </div>

      <% if @tracks.any? %>
        <div class="table-responsive">
          <table class="table table-hover table-bordered align-middle mb-0 small">
            <thead>
              <tr>
                <th scope="col">Giorno</th>
                <th scope="col">Task</th>
                <th scope="col">Progetto</th>
                <th scope="col">Utente</th>
                <th scope="col">Durata</th>
                <th scope="col" class="text-end" style="width: 1px; white-space: nowrap;"><span class="visually-hidden">Azioni</span></th>
              </tr>
            </thead>
            <tbody>
              <% @tracks.each do |track| %>
                <tr>
                  <td><%= track.start_at&.strftime('%d/%m/%Y') %></td>
                  <td>
                    <a href="<%= tasks_show_path(track.task_id) %>" data-turbo-frame="_top">
                      <%= track.task&.title || '—' %>
                    </a>
                  </td>
                  <td>
                    <% if track.task&.project %>
                      <a href="<%= projects_show_path(track.task.project_id) %>" data-turbo-frame="_top">
                        <%= track.task.project.name %>
                      </a>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td><%= track.user&.complete_name || '—' %></td>
                  <td>
                    <% if track.end_at %>
                      <%= track_time(track.time_spent) %>
                    <% else %>
                      <span class="badge bg-info text-white">in corso</span>
                    <% end %>
                  </td>
                  <td class="text-end" style="width: 1px; white-space: nowrap;">
                    <a
                      href="<%= tasks_destroy_track_action_path(track_id: track.id, project_id: @project_id, task_id: @task&.id, page: params[:page]) %>"
                      data-turbo-method="post"
                      data-turbo-confirm="Vuoi eliminare questo tracking? Il tempo verrà sottratto dal task."
                      data-turbo-frame="tracks-list"
                      class="btn btn-sm btn-danger"
                      aria-label="Elimina tracking"
                      data-user-policies-target="item" data-policy="tasks_track"
                    ><i class="bi bi-trash"></i></a>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <% if @tracks.total_pages > 1 %>
          <div class="d-flex justify-content-center mt-3">
            <%= paginate @tracks, theme: 'bootstrap-5' %>
          </div>
        <% end %>
      <% else %>
        <%= render 'shared/placeholder', message: 'Nessun tracking registrato', icon: 'clock-history' %>
      <% end %>

    </div>
  </div>

<% end %>
