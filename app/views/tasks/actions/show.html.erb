<%= render 'shared/action-container', title: 'Dettagli task', size: 'lg' do %>

<div class="d-flex flex-column flex-md-row-reverse">
  <div class="w-100">
    <h3 class="fs-5"><%= @task.title %></h3>
    <h4 class="fs-6 text-muted"><%= @task.completed ? @task.completed_at_in_words : @task.deadline_in_words %></h4>
    <%= render 'tasks/shared/card-content', task: @task %>
    <% unless @task.description.blank? %>
      <hr>
      <%= @task.content %>
    <% end %>
    <% unless @task.tasks_checks.empty? %>
      <hr>
      <%= render 'tasks/shared/checks', task: @task, frame_id: SecureRandom.hex(3) %>
    <% end %>
    <hr class="mt-3 mb-2">
    <p class="text-muted small text-uppercase fw-semibold mb-2" style="letter-spacing: 0.05em;">
      Commenti
    </p>
    <%= render 'tasks/shared/comments', task: @task %>
  </div>

  <hr class="d-md-none">
  <div class="h-md-less-border-end-none border-end pe-md-3 me-md-3">
    <%= render 'tasks/shared/actions', task: @task, context: 'overlay' %>
  </div>
</div>
<% end %>
