<%= render 'shared/page-header', title: 'Board', render_actions: 'procedures/index-actions' %>

<%= render 'shared/page-preferred',
    query: @procedures_preferred,
    type: 'Procedure',
    render_item: 'procedures/shared/card',
    render_item_param: :procedure
  %>

<%= render 'shared/page-index',
    query: @procedures,
    render_item: 'procedures/shared/card',
    render_item_param: :procedure,
    search: true,
    filters: [
      { label: 'Attivi', value: 'not-archived', default: true },
      { label: 'Archiviati', value: 'archived' },
      { label: 'Modelli', value: 'model' }
    ],
    empty_message: 'Nessuna board qui',
    empty_icon: 'kanban',
    empty_cta_label: 'Crea la prima board',
    empty_cta_href: procedures_actions_path(type: 'create'),
    empty_cta_policy: 'procedures_create'
  %>