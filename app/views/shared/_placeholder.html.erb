<%

message ||= 'Nessun elemento da visualizzare'
icon ||= 'book'
cta_label ||= nil
cta_href ||= nil
cta_policy ||= nil
cta_turbo_frame ||= 'action'

%>

<div class="text-center text-muted pt-5 pb-5">
  <div class="fs-1 mb-3"><i class="bi bi-<%= icon %>"></i></div>
  <h3 class="fs-5"><%= message %></h3>

  <% if cta_label.present? && cta_href.present? %>
    <a
      class="btn btn-primary mt-3"
      href="<%= cta_href %>"
      data-turbo-frame="<%= cta_turbo_frame %>"
      <% if cta_policy.present? %>data-user-policies-target="item" data-policy="<%= cta_policy %>"<% end %>
    >
      <i class="bi bi-plus-circle me-1"></i> <%= cta_label %>
    </a>
  <% end %>
</div>
