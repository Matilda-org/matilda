<%= render 'shared/page-header', title: 'Progetti', subtitle: @folder && "<a href='#{folders_show_path(@folder)}' data-turbo='false'>#{@folder&.name}</a>", render_actions: 'projects/index-actions' %>

<%= render 'shared/page-preferred',
    query: @projects_preferred,
    type: 'Project',
    render_item: 'projects/shared/card-interactive',
    render_item_param: :project
  %>

<%= render 'shared/page-index',
  query: @projects,
  render_item: 'projects/shared/card-interactive',
  render_item_param: :project,
  search: true,
  filters: [
    { label: I18n.t('app.labels.actives'), value: 'not-archived', default: true },
    { label: I18n.t('app.labels.archived'), value: 'archived' }
  ],
  sorts: [
    { label: "#{I18n.t('app.labels.name')} ASC", value: 'name_asc', default: true },
    { label: "#{I18n.t('app.labels.name')} DESC", value: 'name_desc' },
    { label: "#{I18n.t('app.labels.year')} ASC", value: 'year_asc' },
    { label: "#{I18n.t('app.labels.year')} DESC", value: 'year_desc' }
  ]
%>