<%= render 'shared/page-header', title: 'Bacheca', render_actions: 'posts/index-actions' %>

<%= render 'shared/page-preferred',
    query: @posts_preferred,
    type: 'Post',
    render_item: 'posts/shared/card',
    render_item_param: :post
  %>

<%= render 'shared/page-index',
    query: @posts,
    render_item: 'posts/shared/card',
    render_item_param: :post,
    tags: @tags,
    search: true,
    empty_message: 'Ancora nessun post in bacheca',
    empty_icon: 'pin-angle',
    empty_cta_label: 'Crea il primo post',
    empty_cta_href: posts_actions_path(type: 'create'),
    empty_cta_policy: 'posts_create'
  %>
