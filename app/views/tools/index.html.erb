<%= render 'shared/page-header', title: 'Strumenti' %>

<%= render 'shared/page-grid' do %>

  <%= render 'shared/page-grid-item' do %>

    <div class="card w-100">
      <div class="card-body d-flex flex-column justify-content-between">
        <div>
          <h5 class="card-title">Controllo progetti su board</h5>
          <p class="card-text">Visualizza i progetti senza procedure associate.</p>
        </div>
        <a href="<%= tools_projects_without_procedures_path %>" class="card-link mt-3" data-turbo-frame="_top">Visualizza</a>
      </div>
    </div>

  <% end %>

  <%= render 'shared/page-grid-item' do %>

    <div class="card w-100">
      <div class="card-body d-flex flex-column justify-content-between">
        <div>
          <h5 class="card-title">Report attività svolte</h5>
          <p class="card-text">Visualizza il report delle attività svolte per periodo.</p>
        </div>
        <a href="<%= tools_projects_tasks_tracking_path %>" class="card-link mt-3" data-turbo-frame="_top">Visualizza</a>
      </div>
    </div>

  <% end %>

  <%= render 'shared/page-grid-item' do %>

    <div class="card w-100">
      <div class="card-body d-flex flex-column justify-content-between">
        <div>
          <h5 class="card-title">Integrazione OpenCode</h5>
          <p class="card-text">Stato della connessione OpenCode con Matilda per monitoraggio.</p>
        </div>
        <% if @opencode_integration && @opencode_integration[:timestamp]&.to_i >= 6.minutes.ago.to_i %>
          <div class="mt-3">
            <span class="badge bg-success">Attivo</span>
            <small class="text-muted d-block mt-2">Macchina: <b><%= @opencode_integration[:machine] %></b></small>
          </div>
        <% else %>
          <div class="mt-3">
            <span class="badge bg-danger">Inattivo</span>
          </div>
        <% end %>
      </div>
    </div>

  <% end %>

<% end %>

