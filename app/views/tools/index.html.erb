<%= render 'shared/page-header', title: 'Strumenti' %>

<%= render 'shared/page-grid' do %>

  <%= render 'shared/page-grid-item' do %>

    <div class="card w-100 shadow h-100 border-0">
      <div class="card-body d-flex flex-column justify-content-between p-4">
        <div>
          <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 46px; height: 46px;">
              <i class="bi bi-kanban-fill fs-5"></i>
            </span>
            <span class="badge rounded-pill bg-light text-primary">Operatività</span>
          </div>
          <h5 class="card-title mb-2">Controllo progetti su board</h5>
          <p class="card-text text-muted mb-0">Trova i progetti che non sono ancora collegati alle board operative.</p>
        </div>
        <a href="<%= tools_projects_without_procedures_path %>" class="btn btn-outline-primary mt-4 align-self-start" data-turbo-frame="_top">Apri controllo</a>
      </div>
    </div>

  <% end %>

  <%= render 'shared/page-grid-item' do %>

    <div class="card w-100 shadow h-100 border-0">
      <div class="card-body d-flex flex-column justify-content-between p-4">
        <div>
          <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 46px; height: 46px;">
              <i class="bi bi-clock-history fs-5"></i>
            </span>
            <span class="badge rounded-pill bg-light text-primary">Analisi</span>
          </div>
          <h5 class="card-title mb-2">Report attività svolte</h5>
          <p class="card-text text-muted mb-0">Analizza il tempo consuntivato per periodo, progetto, board e stato.</p>
        </div>
        <a href="<%= tools_projects_tasks_tracking_path %>" class="btn btn-outline-primary mt-4 align-self-start" data-turbo-frame="_top">Apri report</a>
      </div>
    </div>

  <% end %>

  <%= render 'shared/page-grid-item' do %>

    <div class="card w-100 shadow h-100 border-0">
      <div class="card-body d-flex flex-column justify-content-between p-4">
        <div>
          <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="rounded-circle bg-danger text-white d-inline-flex align-items-center justify-content-center" style="width: 46px; height: 46px;">
              <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            </span>
            <span class="badge rounded-pill bg-danger">Nuovo</span>
          </div>
          <h5 class="card-title mb-2">Rischi progetto</h5>
          <p class="card-text text-muted mb-0">Individua progetti con task scaduti, senza owner, budget critici o attività ferme.</p>
        </div>
        <a href="<%= tools_project_risks_path %>" class="btn btn-danger mt-4 align-self-start" data-turbo-frame="_top">Controlla rischi</a>
      </div>
    </div>

  <% end %>

<% end %>
